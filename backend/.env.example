# Server
APP_ENV=development
APP_PORT=8000
BASE_URL=http://localhost:8000

# Database (default: SQLite untuk development, ganti ke PostgreSQL untuk production)
DATABASE_URL=sqlite:///./siprios.db

# JWT
SECRET_KEY=ganti-dengan-random-string-sangat-panjang
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Object Storage (untuk foto & surat PDF)
STORAGE_PROVIDER=local         # local | s3 | minio
STORAGE_BUCKET=siprios-files
STORAGE_REGION=ap-southeast-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=http://localhost:8000/static

# Upload limits
MAX_FILE_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_DOC_TYPES=application/pdf

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# Admin default (seed pertama kali — ganti sebelum deploy!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_dengan_password_aman
ADMIN_NAMA=Administrator SIPRIOS
